# Build directories
/build/
/build-ninja/
/out/
/cmake-build-*/

# IDE and editor files
.vs/
.vscode/
*.suo
*.user
*.sln.docstates
.idea/

# Compiled binaries
*.exe
*.dll
*.so
*.dylib
*.lib
*.a
*.o
*.obj

# SPIR-V compiled shaders (regenerated from source)
*.spv

# Third-party libraries (downloaded separately)
/third_party/glfw*/
/third_party/glm/
/third_party/nlohmann/
/third_party/openal-soft*/
/third_party/stb/
/third_party/imgui/
